@{
    ViewData["Title"] = "Hospitals";
    var hospitals = ViewBag.Hospitals as System.Data.DataTable;
}

<div class="page-header">
    <div>
        <h1>Hospital Network</h1>
        <p>Bed capacity and patient distribution</p>
    </div>
    <div style="display:flex;gap:10px">
        <a asp-action="Patients" class="btn btn-secondary"><i class="fas fa-procedures"></i> Patients</a>
        <a asp-action="Admit"    class="btn btn-primary"><i class="fas fa-plus"></i> Admit Patient</a>
    </div>
</div>

<div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:18px">
    @if (hospitals != null && hospitals.Rows.Count > 0)
    {
        foreach (System.Data.DataRow row in hospitals.Rows)
        {
            int total     = Convert.ToInt32(row["TotalBeds"]);
            int available = Convert.ToInt32(row["AvailableBeds"]);
            int occupied  = total - available;
            int critical  = Convert.ToInt32(row["CriticalCases"]);
            int pct       = total > 0 ? occupied * 100 / total : 0;
            string barCss = pct >= 90 ? "progress-red" : pct >= 60 ? "progress-orange" : "progress-green";

            <div class="card">
                <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:14px">
                    <div>
                        <div style="font-weight:700;font-size:16px">@row["Name"]</div>
                        <div style="font-size:12px;color:var(--text-muted);margin-top:3px">
                            <i class="fas fa-map-marker-alt" style="color:var(--accent);margin-right:4px"></i>@row["Location"]
                        </div>
                    </div>
                    @if (critical > 0)
                    {
                        <span class="badge badge-critical"><i class="fas fa-heartbeat"></i> @critical Critical</span>
                    }
                </div>

                <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;margin-bottom:14px;text-align:center">
                    <div style="background:var(--bg-primary);border-radius:8px;padding:10px">
                        <div style="font-size:22px;font-weight:700">@total</div>
                        <div style="font-size:11px;color:var(--text-muted)">Total</div>
                    </div>
                    <div style="background:var(--bg-primary);border-radius:8px;padding:10px">
                        <div style="font-size:22px;font-weight:700;color:var(--accent-3)">@available</div>
                        <div style="font-size:11px;color:var(--text-muted)">Available</div>
                    </div>
                    <div style="background:var(--bg-primary);border-radius:8px;padding:10px">
                        <div style="font-size:22px;font-weight:700;color:var(--accent)">@occupied</div>
                        <div style="font-size:11px;color:var(--text-muted)">Occupied</div>
                    </div>
                </div>

                <div style="margin-bottom:6px;display:flex;justify-content:space-between;font-size:12px;color:var(--text-muted)">
                    <span>Occupancy</span><span>@pct%</span>
                </div>
                <div class="progress-bar-wrap">
                    <div class="progress-bar-fill @barCss" style="width:@pct%"></div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="card" style="grid-column:1/-1;text-align:center;color:var(--text-muted);padding:48px">
            <i class="fas fa-hospital" style="font-size:36px;display:block;margin-bottom:14px;opacity:.3"></i>
            No hospitals registered
        </div>
    }
</div>
