@{
    ViewData["Title"] = "Assign Rescue Team";
    var reports = ViewBag.Reports as System.Data.DataTable;
    var teams   = ViewBag.Teams   as System.Data.DataTable;
}

<div class="page-header">
    <div><h1>Assign Rescue Team</h1><p>Assign an available team to an active emergency</p></div>
    <a asp-action="Index" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Back</a>
</div>

<div class="card" style="max-width:680px">
    <form method="post" asp-action="Assign">
        <div class="form-grid">
            <div class="form-group" style="grid-column:1/-1">
                <label>Emergency Report <span style="color:var(--accent-red)">*</span></label>
                <select name="reportID" id="reportID" class="form-control" required>
                    <option value="">— Select Emergency —</option>
                    @if (reports != null)
                    {
                        foreach (System.Data.DataRow row in reports.Rows)
                        {
                            <option value="@row["ReportID"]">
                                #@row["ReportID"] — @row["Location"] (@row["DisasterType"], Sev @row["SeverityLevel"])
                            </option>
                        }
                    }
                </select>
            </div>
            <div class="form-group" style="grid-column:1/-1">
                <label>Available Team <span style="color:var(--accent-red)">*</span></label>
                <select name="teamID" id="teamID" class="form-control" required>
                    <option value="">— Select Team —</option>
                    @if (teams != null)
                    {
                        foreach (System.Data.DataRow row in teams.Rows)
                        {
                            <option value="@row["TeamID"]">
                                @row["TeamName"] (@row["TeamType"]) — @(row["CurrentLocation"] == DBNull.Value ? "Unknown" : row["CurrentLocation"])
                            </option>
                        }
                    }
                </select>
            </div>
        </div>
        <div style="margin-top:24px;display:flex;gap:10px">
            <button type="submit" class="btn btn-primary"><i class="fas fa-paper-plane"></i> Assign Team</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>
